.page-transition {
  animation: page-enter 320ms var(--ease-standard) both;
}

.page-transition-exit {
  animation: page-exit 180ms var(--ease-standard) both;
}

/*
 * Анимация использует только opacity и margin-top (не transform),
 * потому что transform на родителе создаёт новый containing block
 * для всех потомков с position: fixed (например, модальных окон,
 * лайтбокса в галерее). Это привело к тому, что модалки "приклеивались"
 * к контейнеру страницы вместо окна браузера и визуально обрезались.
 */
@keyframes page-enter {
  from {
    opacity: 0;
    margin-top: 10px;
  }
  to {
    opacity: 1;
    margin-top: 0;
  }
}

@keyframes page-exit {
  from {
    opacity: 1;
    margin-top: 0;
  }
  to {
    opacity: 0;
    margin-top: -6px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .page-transition,
  .page-transition-exit {
    animation: none;
  }
}
