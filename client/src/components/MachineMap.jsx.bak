import { useEffect } from 'react';
import { MapContainer, TileLayer, Marker, Popup, useMap } from 'react-leaflet';
import L from 'leaflet';
import 'leaflet/dist/leaflet.css';
import './MachineMap.css';

// React-Leaflet по умолчанию не находит иконки маркеров в сборке Vite,
// поэтому собираем кастомную SVG-иконку в фирменных цветах.
const machineIcon = L.divIcon({
  className: 'machine-marker',
  html: `<span class="machine-marker-dot"></span>`,
  iconSize: [22, 22],
  iconAnchor: [11, 11],
});

const AKTAU_CENTER = [43.6505, 51.18];

function FlyToMachine({ machine }) {
  const map = useMap();

  useEffect(() => {
    if (machine) {
      map.flyTo([machine.lat, machine.lng], 15, { duration: 0.8 });
    }
  }, [machine, map]);

  return null;
}

export default function MachineMap({ machines, selectedMachine, onSelectMachine, onOpenGallery }) {
  return (
    <MapContainer
      center={AKTAU_CENTER}
      zoom={13}
      scrollWheelZoom
      className="machine-map"
    >
      <TileLayer
        attribution='&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
        url="https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png"
      />

      {machines.map((machine) => (
        <Marker
          key={machine.id}
          position={[machine.lat, machine.lng]}
          icon={machineIcon}
          eventHandlers={{
            click: () => onSelectMachine(machine),
          }}
        >
          <Popup>
            <div className="map-popup">
              <strong>{machine.address}</strong>
              <span className="tag tag-price map-popup-price">1 л — 10 ₸</span>
              <p>{machine.description}</p>
              {machine.photos && machine.photos[0] && (
                <img src={machine.photos[0]} alt={machine.address} className="map-popup-image" />
              )}
              <button
                type="button"
                className="btn btn-primary map-popup-btn"
                onClick={() => onOpenGallery(machine)}
              >
                Открыть галерею
              </button>
            </div>
          </Popup>
        </Marker>
      ))}

      {selectedMachine && <FlyToMachine machine={selectedMachine} />}
    </MapContainer>
  );
}
