{
  "version": 3,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "https://aktauvenddd.onrender.com/api/$1" },
    { "src": "/images/(.*)", "dest": "https://aktauvenddd.onrender.com/images/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
