// Координаты города Актау, Казахстан
const AKTAU_LAT = 43.6510;
const AKTAU_LON = 51.1694;

const WEATHER_CODE_MAP = {
  0: 'Ясно',
  1: 'Преимущественно ясно',
  2: 'Переменная облачность',
  3: 'Облачно',
  45: 'Туман',
  48: 'Изморозь',
  51: 'Лёгкая морось',
  53: 'Морось',
  55: 'Сильная морось',
  61: 'Небольшой дождь',
  63: 'Дождь',
  65: 'Сильный дождь',
  71: 'Небольшой снег',
  73: 'Снег',
  75: 'Сильный снег',
  80: 'Ливень',
  81: 'Сильный ливень',
  82: 'Очень сильный ливень',
  95: 'Гроза',
  96: 'Гроза с градом',
  99: 'Сильная гроза с градом',
};

/**
 * Проксирует запрос к Open-Meteo, чтобы:
 * 1) скрыть детали внешнего API от клиента;
 * 2) избежать проблем с CORS на фронтенде;
 * 3) при необходимости добавить кэширование в будущем.
 */
async function getCurrentWeather(req, res) {
  try {
    const url = `https://api.open-meteo.com/v1/forecast?latitude=${AKTAU_LAT}&longitude=${AKTAU_LON}&current_weather=true&timezone=Asia%2FAlmaty`;

    const response = await fetch(url);
    if (!response.ok) {
      throw new Error(`Open-Meteo вернул статус ${response.status}`);
    }

    const data = await response.json();
    const current = data.current_weather;

    res.json({
      success: true,
      city: 'Актау',
      temperature: current.temperature,
      windSpeed: current.windspeed,
      weatherCode: current.weathercode,
      description: WEATHER_CODE_MAP[current.weathercode] || 'Нет данных',
      isDay: current.is_day === 1,
      observedAt: current.time,
    });
  } catch (err) {
    console.error('[weather] Ошибка получения погоды:', err.message);
    res.status(502).json({ success: false, message: 'Не удалось получить данные о погоде' });
  }
}

module.exports = { getCurrentWeather };
