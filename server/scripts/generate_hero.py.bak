"""
Генерирует фирменный hero-фон для главной страницы: ряд вендинговых автоматов
на стилизованной городской подложке, в цветах AKTAUVEND.
Это собственная векторная иллюстрация, а не сгенерированное фото — соответствует
инженерному, минималистичному стилю бренда.
"""
import os
from PIL import Image, ImageDraw

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
OUT = os.path.join(SCRIPT_DIR, "..", "..", "client", "src", "assets", "hero-bg.png")

W, H = 2400, 1500
NAVY = (11, 37, 69)
NAVY_DEEP = (7, 24, 46)
BLUE = (29, 95, 191)
LIGHT_BLUE = (63, 169, 245)
WHITE = (255, 255, 255)

def lerp(a, b, t):
    return tuple(int(a[i] + (b[i]-a[i])*t) for i in range(3))

img = Image.new("RGB", (W, H), NAVY)
draw = ImageDraw.Draw(img)

# вертикальный градиент фона (тёмно-синий -> чуть светлее снизу)
for y in range(H):
    t = y / H
    color = lerp(NAVY_DEEP, NAVY, t)
    draw.line([(0, y), (W, y)], fill=color)

# абстрактный городской силуэт на горизонте
import random
random.seed(7)
horizon = H * 0.62
x = 0
while x < W:
    bw = random.randint(80, 220)
    bh = random.randint(int(H*0.08), int(H*0.28))
    draw.rectangle([x, horizon - bh, x + bw, horizon], fill=lerp(NAVY, NAVY_DEEP, 0.4))
    x += bw + random.randint(4, 18)

# линия горизонта/тротуара
draw.rectangle([0, horizon, W, horizon + 6], fill=LIGHT_BLUE)

# ряд стилизованных вендинговых автоматов на переднем плане
machine_count = 5
gap = 60
total_w = W * 0.86
mw = (total_w - gap*(machine_count-1)) / machine_count
mh = H * 0.32
start_x = (W - total_w) / 2
base_y = horizon + 6

colors_cycle = [WHITE, lerp(WHITE, LIGHT_BLUE, 0.15)]

for i in range(machine_count):
    mx = start_x + i*(mw+gap)
    my = base_y - mh
    body_col = colors_cycle[i % 2]
    draw.rounded_rectangle([mx, my, mx+mw, my+mh], radius=14, fill=body_col, outline=LIGHT_BLUE, width=4)
    # верх
    draw.rounded_rectangle([mx+mw*0.08, my+mh*0.05, mx+mw*0.92, my+mh*0.16], radius=6, fill=NAVY)
    # стекло
    gy0 = my+mh*0.22
    gy1 = my+mh*0.68
    draw.rounded_rectangle([mx+mw*0.1, gy0, mx+mw*0.9, gy1], radius=8, fill=lerp(WHITE, LIGHT_BLUE, 0.35), outline=LIGHT_BLUE, width=2)
    # товары
    rows, cols = 3, 3
    cw = (mw*0.7)/cols
    ch = (gy1-gy0-20)/rows
    prod_colors = [BLUE, LIGHT_BLUE, NAVY]
    for r in range(rows):
        for c in range(cols):
            px = mx+mw*0.1+10+c*cw+cw*0.15
            py = gy0+10+r*ch+ch*0.1
            draw.rounded_rectangle([px, py, px+cw*0.7, py+ch*0.75], radius=4, fill=prod_colors[(r+c+i)%3])
    # клавиатура
    ky0 = gy1+mh*0.04
    ky1 = ky0+mh*0.08
    draw.rounded_rectangle([mx+mw*0.1, ky0, mx+mw*0.9, ky1], radius=6, fill=lerp(WHITE, NAVY, 0.05))
    # отдел выдачи
    draw.rounded_rectangle([mx+mw*0.32, ky1+mh*0.03, mx+mw*0.68, my+mh-mh*0.03], radius=4, fill=NAVY)

# мягкое затемнение слева для читаемости текста хедера
overlay = Image.new("RGBA", (W, H), (0,0,0,0))
odraw = ImageDraw.Draw(overlay)
for x in range(0, int(W*0.65)):
    t = x / (W*0.65)
    alpha = int(190 * (1-t))
    odraw.line([(x,0),(x,H)], fill=(7,24,46,alpha))
img = Image.alpha_composite(img.convert("RGBA"), overlay).convert("RGB")

img.save(OUT, "PNG", optimize=True)
print("saved", OUT, img.size)
